{
    "log":{
        "loglevel": "debug"
    },
    "inbounds":[
        {
      "tag": "trojan",
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "trojan",
      "settings": {
         "users": [
          {
            "password": "pwd123",
            "email": "love@xray.com",
            "level": 0
          }
        ],
        "fallbacks": [
          {
            "dest": "nginx:80"
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {
            "host": "nfw1.online",
            "path": "/uaz", 
            "mode": "auto",
            "extra": {
              "xmux": {
                "maxConnections": 1
              }
            }
        },
        
	"security": "tls",
        "tlsSettings":{
          "serverName": "nfw1.online",
          "allowInsecure": false,
          "alpn": ["h2", "http/1.1"],
          "certificates":[
            {
            "certificateFile": "/etc/cert.crt",
            "keyFile": "/etc/key.key"
          }
          ]
        }
      },
      
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    },
    {
      "protocol": "vless",
      "listen": "0.0.0.0",
      "port": 53,
      "settings": {
        "clients": [
          {"id":"twelc"}
        ],
        "decryption":"none"
      },
      "streamSettings":{
        "network":"mkcp",
        "kcpSettings":{
          "mtu":900
        },
        "finalmask":{
          "udp":[
            {
              "type":"xdns",
              "settings":{
                "domains":["t.nfwmedia.site"]
              }
            }
          ]
        }
      }
    }

    ],
    "outbounds":[
      {
        "tag": "direct",
        "protocol": "freedom"
      },
      {
        "tag": "warp",
        "protocol": "socks",
        "settings":{
          "address": "warp",
          "port": 1080
        }
      },
      {
        "tag": "block",
        "protocol": "blackhole"
      }
    ],

    "routing":{
      "rules": [
    {
      "type": "field",
      "domain": ["geosite:youtube"],
      "outboundTag": "direct"
    },
    {
      "type": "field",
      "domain": ["geosite:google"],
      "outboundTag": "warp"
    }
  ]        
    }
}
