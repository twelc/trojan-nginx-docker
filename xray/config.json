{
    "log":{
        "loglevel": "debug"
    },
    "inbounds":[
        {
      "tag": "vless-xhttp",
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "users": [
          {
            "id": "twelc",
            "level": 0,
            "email": "love@xray.com"            
          }
        ],
        "decryption": "mlkem768x25519plus.native.600s.qEs8VsHnoD4YB9-iBXWsYbvC9IcdEVuQ8Tz1pWXKyF8",
        "fallbacks": [
          {
            "dest": "nginx:80"
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {
            "host": "abghdh.duckdns.org",
            "path": "/uaz", 
            "mode": "auto",
            "extra": {
              "xmux": {
                "maxConnections": 1
              }
            }
        },
        
	"security": "tls",
        "tlsSettings":{
          "serverName": "abghdh.duckdns.org",
          "allowInsecure": false,
          "alpn": ["h2", "http/1.1"],
          "certificates":[
            {
            "certificateFile": "/etc/cert.crt",
            "keyFile": "/etc/key.key"
          }
          ]
        }
      },
      
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }

    ],
    "outbounds":[
      {
        "tag": "direct",
        "protocol": "freedom"
      },
      {
        "tag": "warp",
        "protocol": "socks",
        "settings":{
          "address": "warp",
          "port": 1080
        }
      },
      {
        "tag": "block",
        "protocol": "blackhole"
      }
    ],

    "routing":{
      "rules": [
    {
      "type": "field",
      "domain": ["geosite:youtube"],
      "outboundTag": "direct"
    },
    {
      "type": "field",
      "domain": ["geosite:google"],
      "outboundTag": "warp"
    },
    {
      "type": "field",
      "domain": ["geoip:ru"],
      "outboundTag": "block"
    }
  ]        
    }
}
